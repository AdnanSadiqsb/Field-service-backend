{
  "framework": null,
  "installCommand": "pip install --upgrade pip setuptools wheel && pip install -r requirements/vercel.txt",
  "buildCommand": "echo 'Build complete'",
  "env": {
    "DJANGO_SETTINGS_MODULE": "src.config.production",
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "."
  },
  "regions": ["iad1"],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
