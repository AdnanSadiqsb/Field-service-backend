{
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "python manage.py collectstatic --noinput",
  "env": {
    "DJANGO_SETTINGS_MODULE": "src.config.production",
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "."
  },
  "regions": ["iad1"],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
